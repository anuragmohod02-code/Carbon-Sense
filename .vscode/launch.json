{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Carbon Sense Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/vscode-ext/carbon-sense"
      ],
      "outFiles": [
        "${workspaceFolder}/vscode-ext/carbon-sense/out/**/*.js"
      ],
      "preLaunchTask": "carbon-sense: compile"
    }
  ]
}
